# LLM-as-a-Judge Configuration
# Set either of the following keys to enable semantic testing with "npm run doctor:judge"

# DeepSeek API Key (e.g. sk-...)
DEEPSEEK_API_KEY=

# OpenRouter API Key (e.g. sk-or-...)
OPENROUTER_API_KEY=

# Optional: Override the model used by the judge.
# For DeepSeek, defaults to "deepseek-v4-flash".
# For OpenRouter, defaults to "google/gemini-2.5-pro".
JUDGE_MODEL=

# Optional: Path to a sacrificial/testing project for changeMode E2E tests
CHANGEMODE_PROJECT_PATH=
